# new-api 生产部署环境变量模板
# 使用方法：复制本文件为 /opt/new-api/data/.env 并按需修改

# --- 数据库（MySQL 内置容器） ---
MYSQL_ROOT_PASSWORD=replace_with_strong_mysql_root_password
MYSQL_DATABASE=new-api
# 应用连接串（与上面密码/库名匹配）
SQL_DSN=root:replace_with_strong_mysql_root_password@tcp(mysql:3306)/new-api?parseTime=true

# --- 缓存（Redis 内置容器） ---
REDIS_CONN_STRING=redis://redis:6379/0

# --- 基本运行参数 ---
TZ=Asia/Shanghai
ERROR_LOG_ENABLED=true

# --- ClawBox Portable GitHub Release 访问 ---
# 如果配置的 ClawBox 仓库是私有的，需要提供一个可读取 releases 的 GitHub token，
# 供 /api/clawbox/update/portable/releases/sync/github 和下载代理使用。
# ONEAPI_CLAWBOX_PORTABLE_GITHUB_TOKEN=github_pat_xxx

# --- 请求链路全量追踪（Request Trace / Full Request+Response Capture） ---
# 用于按 request_id 点查一次请求在 new-api /（可选）embedded codex-service-go / 上游之间的完整链路：
# - 请求头/请求体
# - 响应头/响应体
#
# 存储方式：
# - MySQL：仅存索引与引用（request_trace_sessions / request_trace_nodes），用于按 request_id 查询
# - 文件：保存 headers/body 原文（无 KB 上限，流式落盘）
#
# 安全提示：会持久化敏感头（例如 Authorization/Cookie 等），仅建议在内网/受控环境启用，
# 并确保控制台/接口权限限制（当前 /api/request_trace/* 仅管理员可访问）。
#
# 范围：默认仅追踪 /v1* 与 /v1beta*（避免把控制台等后台请求也写入 trace）
# - 推荐：通过控制台「设置 -> 运营设置 -> 日志设置」切换 request_trace.enabled（可热更新）
# - env REQUEST_TRACE_ENABLED 作为默认值（启动时读取）
REQUEST_TRACE_ENABLED=false
# 对象落盘目录（容器内路径）。建议落在 /app/logs（docker-compose 已挂载到宿主机 ./logs）
# 为了让 embedded codex-service-go 与 new-api 写到同一套对象目录，建议显式统一为：
REQUEST_TRACE_SPOOL_DIR=/app/logs/request_traces
#
# 保留天数（0=永久保留）
# - 推荐：通过控制台「设置 -> 运营设置 -> 日志设置」配置 request_trace.retention_days（可热更新）
# - env REQUEST_TRACE_RETENTION_DAYS 作为默认值（启动时读取）
# REQUEST_TRACE_RETENTION_DAYS=0

# --- 安全相关（务必更换为长随机串） ---
SESSION_SECRET=replace_with_long_random_string
CRYPTO_SECRET=replace_with_long_random_string

# --- 可选：多机从节点前端重定向（主节点会忽略） ---
# NODE_TYPE=slave
# FRONTEND_BASE_URL=https://your-frontend-url.com

# 其他可选键请参考 .env.example（开发用）
